# Server Configuration
PORT=3000
INSTANCE_ID=default
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/notification_platform

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-minimum-32-characters

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Logging Configuration
LOG_LEVEL=info

# CORS Configuration (comma-separated origins for production)
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Docker Configuration (for docker-compose)
POSTGRES_PASSWORD=your-postgres-password
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
ALLOWED_ORIGINS=http://localhost
