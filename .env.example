# Server port - override per instance when running multiple servers
# Instance 1: PORT=3000
# Instance 2: PORT=3001
PORT=3000

# Unique identifier for this server instance (used for Redis Pub/Sub deduplication)
# Instance 1: INSTANCE_ID=server-1
# Instance 2: INSTANCE_ID=server-2
INSTANCE_ID=default

NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/notification_platform
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-minimum-32-characters

# Redis configuration - use either REDIS_URL or REDIS_HOST + REDIS_PORT
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

LOG_LEVEL=info
